# ── S3 Configuration (required for all exporters) ────────────────────────
S3_BUCKET=my-export-bucket
S3_PREFIX=

# ── AWS Credentials (or use IAM role / AWS profile) ──────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# ── Common Settings ──────────────────────────────────────────────────────
MAX_WORKERS=5
LOG_LEVEL=INFO
JSON_LOGS=true

# ── GitHub ───────────────────────────────────────────────────────────────
# Auth option 1: Personal Access Token (5,000 req/hr per user)
GITHUB_TOKEN=ghp_YOUR_TOKEN
# Auth option 2: GitHub App (5,000–12,500 req/hr per app, independent pools)
# Create at: Org Settings → Developer settings → GitHub Apps
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY=github-app.pem
# GITHUB_APP_INSTALLATION_ID=78901234
# For multiple apps (comma-separated, round-robin for independent rate limits):
# GITHUB_APP_ID=123,456
# GITHUB_APP_PRIVATE_KEY=app1.pem,app2.pem
# GITHUB_APP_INSTALLATION_ID=111,222
#
# Comma-separated list, or use --input-csv with github_repos.csv:
GITHUB_REPOS=owner/repo-1,owner/repo-2
# GITHUB_INPUT_CSV=github_repos.csv
# GITHUB_PR_LIMIT=500        # 0 or omit = all
GITHUB_PR_STATE=all
# GITHUB_COMMIT_LIMIT=1000   # 0 or omit = all
# GITHUB_SKIP_COMMITS=true
# GITHUB_SKIP_PRS=true

# ── Jira ─────────────────────────────────────────────────────────────────
JIRA_TOKEN=YOUR_API_TOKEN
JIRA_EMAIL=you@company.com
JIRA_DOMAIN=practo.atlassian.net
# Comma-separated list, or use --input-csv with jira_projects.csv:
JIRA_PROJECTS=IES,PLAT,ENG
# JIRA_INPUT_CSV=jira_projects.csv
# JIRA_LIMIT=100             # 0 or omit = all
# JIRA_SKIP_ATTACHMENTS=true
# JIRA_SKIP_COMMENTS=true

# ── Slack ────────────────────────────────────────────────────────────────
SLACK_TOKEN=xoxb-YOUR-BOT-TOKEN
# Comma-separated list, or use --input-csv with slack_channels.csv:
SLACK_CHANNEL_IDS=C090J5ZPP51,C0ABC123456
# SLACK_INPUT_CSV=slack_channels.csv
SLACK_MAX_WORKERS=3
# SLACK_INCLUDE_THREADS=true
# SLACK_SKIP_ATTACHMENTS=true

# ── Confluence ───────────────────────────────────────────────────────────
# Uses same Atlassian credentials as Jira by default (JIRA_TOKEN / JIRA_EMAIL / JIRA_DOMAIN)
# Override only if Confluence uses different credentials:
# CONFLUENCE_TOKEN=YOUR_API_TOKEN
# CONFLUENCE_EMAIL=you@company.com
# CONFLUENCE_DOMAIN=your-domain.atlassian.net
# Comma-separated list, or use --input-csv with confluence_spaces.csv:
CONFLUENCE_SPACES=ENG,PLAT,OPS
# CONFLUENCE_INPUT_CSV=confluence_spaces.csv
# CONFLUENCE_PAGE_LIMIT=0               # 0 or omit = all pages
# CONFLUENCE_SKIP_ATTACHMENTS=false     # default: downloads all attachments
# CONFLUENCE_SKIP_COMMENTS=false        # default: fetches all comments
# CONFLUENCE_BODY_FORMAT=storage        # storage (XHTML) or atlas_doc_format (ADF JSON)
# CONFLUENCE_PARALLEL=1                 # spaces to export in parallel

# ── BigQuery GA4 ────────────────────────────────────────────────────────
BIGQUERY_KEY=path/to/service-account-key.json
BIGQUERY_PROJECT=your-gcp-project-id
BIGQUERY_DATASET=analytics_000000000
# BIGQUERY_DAYS=365              # default 365
# BIGQUERY_END_DATE=20260330     # default: yesterday
# BIGQUERY_PARALLEL=4            # parallel day exports

# ── Google Workspace ─────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_KEY=service-account.json
# Comma-separated list, or use --input-csv with google_users.csv:
GOOGLE_USERS=alice@company.com,bob@company.com
# GOOGLE_INPUT_CSV=google_users.csv
# GOOGLE_EMAIL_LIMIT=500     # 0 or omit = all
# GOOGLE_EVENT_LIMIT=500     # 0 or omit = all
# GOOGLE_FILE_LIMIT=50       # 0 or omit = all
# GOOGLE_SKIP_GMAIL=true
# GOOGLE_SKIP_CALENDAR=true
# GOOGLE_SKIP_DRIVE=true
