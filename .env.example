# ── S3 Configuration (required for all exporters) ────────────────────────
S3_BUCKET=my-export-bucket
S3_PREFIX=

# ── AWS Credentials (or use IAM role / AWS profile) ──────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# ── Common Settings ──────────────────────────────────────────────────────
MAX_WORKERS=5
LOG_LEVEL=INFO
JSON_LOGS=true

# ── GitHub ───────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_YOUR_TOKEN
# Comma-separated list, or use --input-csv with github_repos.csv:
GITHUB_REPOS=owner/repo-1,owner/repo-2
# GITHUB_INPUT_CSV=github_repos.csv
# GITHUB_PR_LIMIT=500        # 0 or omit = all
GITHUB_PR_STATE=all
# GITHUB_COMMIT_LIMIT=1000   # 0 or omit = all
# GITHUB_SKIP_COMMITS=true
# GITHUB_SKIP_PRS=true

# ── Jira ─────────────────────────────────────────────────────────────────
JIRA_TOKEN=YOUR_API_TOKEN
JIRA_EMAIL=you@company.com
JIRA_DOMAIN=org_name.atlassian.net
# Comma-separated list, or use --input-csv with jira_projects.csv:
JIRA_PROJECTS=IES,PLAT,ENG
# JIRA_INPUT_CSV=jira_projects.csv
# JIRA_LIMIT=100             # 0 or omit = all
# JIRA_SKIP_ATTACHMENTS=true
# JIRA_SKIP_COMMENTS=true

# ── Slack ────────────────────────────────────────────────────────────────
SLACK_TOKEN=xoxb-YOUR-BOT-TOKEN
# Comma-separated list, or use --input-csv with slack_channels.csv:
SLACK_CHANNEL_IDS=C090J5ZPP51,C0ABC123456
# SLACK_INPUT_CSV=slack_channels.csv
SLACK_MAX_WORKERS=3
# SLACK_INCLUDE_THREADS=true
# SLACK_SKIP_ATTACHMENTS=true

# ── Confluence ───────────────────────────────────────────────────────────
# Uses same Atlassian credentials as Jira by default (JIRA_TOKEN / JIRA_EMAIL)
# CONFLUENCE_TOKEN=YOUR_API_TOKEN        # falls back to JIRA_TOKEN
# CONFLUENCE_EMAIL=you@company.com       # falls back to JIRA_EMAIL
# CONFLUENCE_DOMAIN=org_name.atlassian.net # falls back to JIRA_DOMAIN
# Comma-separated list, or use --input-csv:
CONFLUENCE_SPACES=ENG,PLAT,OPS
# CONFLUENCE_INPUT_CSV=confluence_spaces.csv
# CONFLUENCE_PAGE_LIMIT=0       # 0 or omit = all
# CONFLUENCE_SKIP_ATTACHMENTS=true
# CONFLUENCE_SKIP_COMMENTS=true
# CONFLUENCE_BODY_FORMAT=storage # or atlas_doc_format

# ── Google Workspace ─────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_KEY=service-account.json
# Comma-separated list, or use --input-csv with google_users.csv:
GOOGLE_USERS=alice@company.com,bob@company.com
# GOOGLE_INPUT_CSV=google_users.csv
# GOOGLE_EMAIL_LIMIT=500     # 0 or omit = all
# GOOGLE_EVENT_LIMIT=500     # 0 or omit = all
# GOOGLE_FILE_LIMIT=50       # 0 or omit = all
# GOOGLE_SKIP_GMAIL=true
# GOOGLE_SKIP_CALENDAR=true
# GOOGLE_SKIP_DRIVE=true
